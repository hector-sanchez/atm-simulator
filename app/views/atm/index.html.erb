<%= stylesheet_link_tag 'atm' %>

<div class="atm-container">
	<div class="atm-screen">
		<!-- Left Panel - Menu -->
		<div class="form-panel">
			<!-- Header -->
			<div class="atm-header">
				<div class="bank-logo">SecureBank ATM</div>

				<%= render 'shared/atm_location_info' %>

				<p>&nbsp;</p>
				<h1 class="welcome-title">
					Welcome, <%= @card_presenter.customer_first_name %>
				</h1>
				<p class="welcome-subtitle">
					<strong><%= @account_presenter.account_type_display %></strong>
					Account: <%= @account_presenter.formatted_account_number %> • Balance:
					<%= @account_presenter.formatted_balance %>
				</p>
			</div>

			<!-- ATM Menu Options -->
			<div class="atm-menu">
				<div class="menu-section">
					<h3 class="menu-title">Select Transaction</h3>

					<div class="menu-options" data-controller="modal-opener">
						<%= link_to transactions_path, class: "menu-option" do %>
							<span class="option-icon">💰</span>
							<span class="option-text">
								<strong>Check Balance</strong>
								<small>View current account balance and recent transactions</small>
							</span>
						<% end %>

						<button
							class="menu-option"
							type="button"
							data-action="click->modal-opener#openModal"
							data-modal-id="debitModal"
						>
							<span class="option-icon">💳</span>
							<span class="option-text">
								<strong>Withdraw Cash</strong>
								<small>Take money from your account</small>
							</span>
						</button>

						<button
							class="menu-option"
							type="button"
							data-action="click->modal-opener#openModal"
							data-modal-id="creditModal"
						>
							<span class="option-icon">💵</span>
							<span class="option-text">
								<strong>Make a deposit</strong>
								<small>Put money in your account</small>
							</span>
						</button>
					</div>
				</div>

				<!-- Logout Button -->
				<%= link_to logout_path, class: "logout-button", data: {
					"turbo-method": "delete",
					confirm: "Are you sure you want to end your session?"
				} do %>
				<span>🚪</span> End Session <% end %>
			</div>
		</div>

		<%= render 'multi_card_panel' %>
	</div>
</div>

<!-- Transaction Modals -->
<%= render 'shared/transaction_modal',
    transaction_type: 'debit',
    account_presenter: @account_presenter %>

<%= render 'shared/transaction_modal',
    transaction_type: 'credit',
    account_presenter: @account_presenter %>
