<%= stylesheet_link_tag 'atm' %>

<div class="atm-container">
	<div class="atm-screen">
		<!-- Left Panel - Menu -->
		<div class="form-panel">
			<!-- Header -->
			<div class="atm-header">
				<div class="bank-logo">SecureBank ATM</div>

				<!-- ATM Location Information -->
				<div class="atm-location-info">
					<div class="location-main">
						<span class="location-icon">📍</span>
						<span class="location-text"><%= @current_atm.location_name %></span>
						<span class="atm-id">ID: <%= @current_atm.machine_id %></span>
					</div>
					<div class="location-details">
						<%= @current_atm.full_address %>
						<% if @selection_reason %>
							<div class="selection-reason"><%= @selection_reason %></div>
						<% end %>
					</div>
				</div>

				<p>&nbsp;</p>
				<h1 class="welcome-title">
					Welcome, <%= @card_presenter.customer_first_name %>
				</h1>
				<p class="welcome-subtitle">
					<strong><%= @account_presenter.account_type_display %></strong>
					Account: <%= @account_presenter.formatted_account_number %> • Balance:
					<%= @account_presenter.formatted_balance %>
				</p>
			</div>

			<!-- ATM Menu Options -->
			<div class="atm-menu">
				<div class="menu-section">
					<h3 class="menu-title">Select Transaction</h3>

					<div class="menu-options" data-controller="modal-opener">
						<%= link_to transactions_path, class: "menu-option" do %>
							<span class="option-icon">💰</span>
							<span class="option-text">
								<strong>Check Balance</strong>
								<small>View current account balance and recent transactions</small>
							</span>
						<% end %>

						<button
							class="menu-option"
							type="button"
							data-action="click->modal-opener#openModal"
							data-modal-id="debitModal"
						>
							<span class="option-icon">💳</span>
							<span class="option-text">
								<strong>Withdraw Cash</strong>
								<small>Take money from your account</small>
							</span>
						</button>

						<button
							class="menu-option"
							type="button"
							data-action="click->modal-opener#openModal"
							data-modal-id="creditModal"
						>
							<span class="option-icon">💵</span>
							<span class="option-text">
								<strong>Make a deposit</strong>
								<small>Put money in your account</small>
							</span>
						</button>
					</div>
				</div>

				<!-- Logout Button -->
				<%= link_to logout_path, class: "logout-button", data: {
					"turbo-method": "delete",
					confirm: "Are you sure you want to end your session?"
				} do %>
				<span>🚪</span> End Session <% end %>
			</div>
		</div>

		<%= render 'multi_card_panel' %>
	</div>
</div>

<!-- Transaction Modals -->
<%= render 'shared/transaction_modal',
    transaction_type: 'debit',
    account_presenter: @account_presenter %>

<%= render 'shared/transaction_modal',
    transaction_type: 'credit',
    account_presenter: @account_presenter %>
<script>
  document.addEventListener('DOMContentLoaded', function() {
    console.log('DOM loaded');
    console.log('testModal element:', document.getElementById('testModal'));
    console.log('debitModal element:', document.getElementById('debitModal'));
    console.log('creditModal element:', document.getElementById('creditModal'));

    // Check all elements with modal-related classes or IDs
    console.log('All modal-overlay elements:', document.querySelectorAll('.modal-overlay'));
    console.log('All elements with IDs containing "Modal":', document.querySelectorAll('[id*="Modal"]'));

    // Check if any div elements contain transaction-related content
    const allDivs = document.querySelectorAll('div');
    let transactionDivs = [];
    allDivs.forEach(div => {
      if (div.innerHTML && (div.innerHTML.includes('Withdraw') || div.innerHTML.includes('Deposit'))) {
        transactionDivs.push(div);
      }
    });
    console.log('Divs with transaction content:', transactionDivs);
  });
</script>
