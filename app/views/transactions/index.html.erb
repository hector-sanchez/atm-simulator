<%= stylesheet_link_tag 'atm' %>

<div class="atm-container">
	<div class="atm-screens">
		<!-- Left Panel - Menu -->
		<div class="form-panel">
			<!-- Header -->
			<div class="atm-header">
				<div class="bank-logo" style="margin-bottom:30px;">SecureBank ATM</div>

				<!-- Header Controls Row -->
				<div class="header-controls-row">
					<!-- ATM Location Information -->
					<div class="atm-location-info atm-location-info-flex">
						<div class="location-main">
							<span class="location-icon">📍</span>
							<span class="location-text"><%= @current_atm.location_name %></span>
							<span class="atm-id">ID: <%= @current_atm.machine_id %></span>
						</div>
						<div class="location-details">
							<%= @current_atm.full_address %>
							<% if @selection_reason %>
								<div class="selection-reason"><%= @selection_reason %></div>
							<% end %>
						</div>
					</div>

					<!-- Action Buttons -->
					<div class="header-action-buttons">
						<!-- End Session Button -->
						<%= link_to logout_path, class: "logout-button", data: {
							"turbo-method": "delete",
							confirm: "Are you sure you want to end your session?"
						} do %>
						<span>🚪</span> End Session <% end %>

						<!-- Back to ATM Dashboard Button -->
						<%= link_to atm_path, class: "btn btn-secondary" do %>
						  <span>🏧</span> ATM Dashboard
			        <% end %>
					</div>
				</div>

        <div>
          <div class="section-header">
            <h1 class="section-title">
              <%= @card_presenter.cardholder_name %>
            </h1>
            <p class="section-subtitle">
              <strong><%= @account_presenter.account_type_display %></strong>
              Account: <%= @account_presenter.formatted_account_number %> • Balance:
              <%= @account_presenter.formatted_balance %>
            </p>
          </div>
        </div>
			</div>

			<div class="atm-menu">
        <div class="transactions-section">
          <% if @transaction_presenters.any? %>
            <div class="section-header">
              <h2 class="section-title">
                Recent Transactions
              </h2>
            </div>
            <div class="transaction-table-containers">
              <table class="transaction-table">
                <thead>
                  <tr>
                    <th>Date & Time</th>
                    <th>Description</th>
                    <th>Type</th>
                    <th>Location</th>
                    <th>Amount</th>
                  </tr>
                </thead>
                <tbody>
                  <% @transaction_presenters.each do |presenter| %>
                    <tr>
                      <td>
                        <div class="transaction-datetime">
                          <div><%= presenter.formatted_date %></div>
                          <div><%= presenter.formatted_time %></div>
                        </div>
                      </td>

                      <td>
                        <div class="transaction-description">
                          <%= presenter.transaction_type_display %>
                          <% if presenter.has_atm_location? %>
                            <div class="transaction-location">
                              <%= presenter.location_name %>
                            </div>
                            <p class="atm-machine-id">ATM ID: <%= presenter.atm_machine_id %></p>
                            <p class="atm-machine-id">Ref No: <%= presenter.reference_number %></p>
                          <% end %>
                        </div>
                      </td>

                      <td>
                        <span class="type-badge <%= presenter.transaction_type.downcase %>">
                          <%= presenter.transaction_type_display %>
                        </span>
                      </td>

                      <td>
                        <% if presenter.has_atm_location? %>
                          <div class="transaction-location">
                            <strong><%= presenter.location_name %></strong><br>
                            <%= presenter.location_address %>
                          </div>
                        <% else %>
                          <span class="transaction-source">
                            🏦 <%= presenter.source_display %>
                          </span>
                        <% end %>
                      </td>

                      <td>
                        <span class="transaction-amount <%= presenter.amount_color_class %>">
                          <%= presenter.amount_with_sign %>
                        </span>
                      </td>
                    </tr>
                  <% end %>
                </tbody>
              </table>
            </div>

            <div class="pagination-wrapper">
              <%= paginate @transactions, theme: 'banking' %>
            </div>
          <% else %>
            <div class="empty-state">
              <div class="empty-state-icon">💳</div>
              <h3 class="empty-state-title">No Transactions Found</h3>
              <p class="empty-state-description">
                You haven't made any transactions yet. When you do, they'll appear here.
              </p>
            </div>
          <% end %>
        </div>
			</div>
		</div>
	</div>
</div>

